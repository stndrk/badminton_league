<% content_for :title, "My Leagues — Badminton League" %>
<% content_for :head do %>
<style>
  .leagues-page { min-height: 100vh; background: var(--dark-0); }

  .top-bar {
    background: var(--dark-1);
    border-bottom: 1px solid var(--dark-3);
    padding: 16px 40px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .top-bar .brand { font-family: 'Bebas Neue', sans-serif; font-size: 24px; letter-spacing: 3px; color: var(--text-pri); }
  .top-bar .brand span { color: var(--lime); }
  .top-bar-right { display: flex; align-items: center; gap: 16px; }

  .user-pill {
    display: flex; align-items: center; gap: 8px;
    background: var(--dark-2); padding: 6px 14px 6px 8px;
    border-radius: 30px; font-size: 13px; color: var(--text-sec);
  }
  .user-pill .avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: linear-gradient(135deg, var(--lime), var(--lime-dim));
    color: var(--dark-0); font-family: 'Bebas Neue', sans-serif;
    font-size: 13px; display: flex; align-items: center; justify-content: center;
  }
  .btn-signout {
    background: transparent; border: 1px solid var(--dark-4); color: var(--text-sec);
    border-radius: 8px; padding: 7px 14px; font-size: 13px; cursor: pointer;
    font-family: 'Outfit', sans-serif; transition: border-color 0.15s, color 0.15s;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .btn-signout:hover { border-color: var(--danger); color: var(--danger); }

  .page-content { max-width: 1100px; margin: 0 auto; padding: 48px 40px; }

  .page-hero { margin-bottom: 40px; }
  .page-hero .eyebrow {
    font-size: 11px; font-weight: 600; letter-spacing: 2px;
    text-transform: uppercase; color: var(--lime); margin-bottom: 10px;
  }
  .page-hero h1 {
    font-family: 'Bebas Neue', sans-serif; font-size: 52px;
    letter-spacing: 2px; color: var(--text-pri); line-height: 1; margin-bottom: 8px;
  }
  .page-hero p { color: var(--text-sec); font-size: 15px; }

  .create-form-wrap {
    background: var(--dark-1); border: 1px solid var(--dark-3);
    border-radius: 14px; padding: 28px 32px; margin-bottom: 32px; display: none;
  }
  .create-form-wrap.open { display: block; }
  .create-form-wrap h3 {
    font-family: 'Bebas Neue', sans-serif; font-size: 20px;
    letter-spacing: 1.5px; color: var(--text-pri); margin-bottom: 18px;
  }
  .create-form-row { display: flex; gap: 12px; align-items: center; }
  .create-form-row input[type="text"] {
    flex: 1; background: var(--dark-2); border: 1.5px solid var(--dark-4);
    border-radius: 8px; padding: 12px 16px; color: var(--text-pri);
    font-family: 'Outfit', sans-serif; font-size: 14px; outline: none;
    transition: border-color 0.2s;
  }
  .create-form-row input[type="text"]:focus { border-color: var(--lime); }
  .create-form-row input::placeholder { color: var(--text-dim); }
  .btn-cancel-form {
    background: transparent; border: 1px solid var(--dark-4); color: var(--text-sec);
    border-radius: 8px; padding: 12px 18px; cursor: pointer;
    font-family: 'Outfit', sans-serif; font-size: 13px; transition: 0.15s;
    white-space: nowrap;
  }
  .btn-cancel-form:hover { border-color: var(--text-sec); color: var(--text-pri); }

  .leagues-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px; margin-bottom: 32px;
  }
  .league-card {
    background: var(--dark-1); border: 1px solid var(--dark-3); border-radius: 14px;
    padding: 24px; position: relative; overflow: hidden; cursor: pointer;
    text-decoration: none; display: block; transition: border-color 0.2s, transform 0.15s;
  }
  .league-card:hover { border-color: var(--lime); transform: translateY(-2px); }
  .league-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--lime), transparent);
  }
  .league-icon {
    width: 44px; height: 44px; background: rgba(198,241,53,0.1);
    border-radius: 10px; display: flex; align-items: center; justify-content: center;
    font-size: 20px; color: var(--lime); margin-bottom: 16px;
  }
  .league-name {
    font-family: 'Bebas Neue', sans-serif; font-size: 24px;
    letter-spacing: 1.5px; color: var(--text-pri); margin-bottom: 4px; line-height: 1;
  }
  .league-owner { font-size: 12px; color: var(--text-sec); margin-bottom: 20px; }
  .league-meta { display: flex; gap: 16px; border-top: 1px solid var(--dark-3); padding-top: 16px; }
  .league-meta-item .val { font-family: 'Bebas Neue', sans-serif; font-size: 22px; color: var(--text-pri); line-height: 1; }
  .league-meta-item .lbl { font-size: 10px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; margin-top: 2px; }
  .league-arrow {
    position: absolute; bottom: 24px; right: 24px; color: var(--text-dim);
    font-size: 18px; transition: color 0.15s, transform 0.15s;
  }
  .league-card:hover .league-arrow { color: var(--lime); transform: translateX(3px); }

  .add-league-card {
    background: transparent; border: 1.5px dashed var(--dark-4); border-radius: 14px;
    padding: 24px; display: flex; flex-direction: column; align-items: center;
    justify-content: center; min-height: 180px; cursor: pointer; text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .add-league-card:hover { border-color: var(--lime); background: rgba(198,241,53,0.03); }
  .add-league-card i { font-size: 28px; color: var(--text-dim); margin-bottom: 10px; transition: color 0.2s; }
  .add-league-card:hover i { color: var(--lime); }
  .add-league-card span {
    font-family: 'Bebas Neue', sans-serif; font-size: 16px;
    letter-spacing: 1.5px; color: var(--text-dim); transition: color 0.2s;
  }
  .add-league-card:hover span { color: var(--lime); }

  .friendly-cta {
    background: var(--dark-1); border: 1px solid var(--dark-3); border-radius: 14px;
    padding: 24px 28px; display: flex; align-items: center; justify-content: space-between;
  }
  .friendly-cta h4 {
    font-family: 'Bebas Neue', sans-serif; font-size: 20px;
    letter-spacing: 1.5px; color: var(--text-pri); margin-bottom: 4px;
  }
  .friendly-cta p { font-size: 13px; color: var(--text-sec); }
  .btn-app {
    background: var(--lime); color: var(--dark-0); border: none; border-radius: 8px;
    padding: 10px 22px; font-family: 'Bebas Neue', sans-serif; font-size: 16px;
    letter-spacing: 1.5px; cursor: pointer; text-decoration: none;
    display: inline-flex; align-items: center; gap: 8px; transition: background 0.15s;
  }
  .btn-app:hover { background: var(--lime-dim); color: var(--dark-0); }
</style>
<% end %>

<div class="top-bar">
  <div class="brand">BADMINTON<span>LEAGUE</span></div>
  <div class="top-bar-right">
    <div class="user-pill">
      <div class="avatar"><%= current_user.name[0].upcase %></div>
      <%= current_user.name %>
    </div>
    <%# button_to generates a proper form with DELETE method %>
    <%= button_to session_path, method: :delete, class: "btn-signout",
          form: { "data-turbo": false } do %>
      <i class="bi bi-box-arrow-right"></i> Sign Out
    <% end %>
  </div>
</div>

<div class="leagues-page">
  <div class="page-content">

    <div class="page-hero">
      <div class="eyebrow">Welcome back, <%= current_user.name.split.first %></div>
      <h1>YOUR LEAGUES</h1>
      <p>Select a league to open the dashboard, or create a new one below.</p>
    </div>

    <%# ── Create League Form (toggled, only for admin/super_admin) ── %>
    <% if current_user.admin? %>
      <div id="create-form-wrap" class="create-form-wrap">
        <h3>CREATE NEW LEAGUE</h3>
        <%# FIX: use model: League.new so fields are namespaced as league[name]
            which matches params.require(:league).permit(:name) in the controller %>
        <%= form_with model: League.new, url: leagues_path, local: true do |f| %>
          <div class="create-form-row">
            <%= f.text_field :name,
                  placeholder: "e.g. Office Smash Cup 2025",
                  autocomplete: "off",
                  required: true %>
            <%= f.submit "CREATE →", class: "btn-app" %>
            <button type="button" class="btn-cancel-form" onclick="toggleCreateForm()">Cancel</button>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Flash errors from failed create ── %>
    <% if flash[:alert] %>
      <div style="background:rgba(255,77,77,0.1);border:1px solid rgba(255,77,77,0.3);border-radius:10px;
                  padding:12px 18px;color:#ff7070;font-size:13px;margin-bottom:20px;display:flex;gap:8px;align-items:center">
        <i class="bi bi-exclamation-circle"></i> <%= flash[:alert] %>
      </div>
    <% end %>

    <%# ── Leagues Grid ── %>
    <div class="leagues-grid">
      <% @leagues.each do |league| %>
        <%= link_to league_path(league), class: "league-card" do %>
          <div>
            <div class="league-icon"><i class="bi bi-shield-fill"></i></div>
            <div class="league-name"><%= league.name %></div>
            <div class="league-owner">Owned by <%= league.owner.name %></div>
            <div class="league-meta">
              <div class="league-meta-item">
                <div class="val"><%= league.members.size %></div>
                <div class="lbl">Players</div>
              </div>
              <div class="league-meta-item">
                <div class="val"><%= league.matches.size %></div>
                <div class="lbl">Matches</div>
              </div>
            </div>
          </div>
          <i class="bi bi-arrow-right league-arrow"></i>
        <% end %>
      <% end %>

      <% if current_user.admin? %>
        <a href="#" class="add-league-card" onclick="toggleCreateForm(); return false;">
          <i class="bi bi-plus-circle"></i>
          <span>NEW LEAGUE</span>
        </a>
      <% end %>
    </div>

    <%# ── Friendly Matches CTA ── %>
    <div class="friendly-cta">
      <div>
        <h4>FRIENDLY MATCHES</h4>
        <p>Record a match without any league — open to all players.</p>
      </div>
      <%= link_to matches_path, class: "btn-app" do %>
        GLOBAL VIEW <i class="bi bi-arrow-right"></i>
      <% end %>
    </div>

  </div>
</div>

<% content_for :scripts do %>
<script>
  function toggleCreateForm() {
    document.getElementById("create-form-wrap").classList.toggle("open");
  }

  <% if @league&.errors&.any? %>
    // Auto-open form if there was a validation error
    document.getElementById("create-form-wrap").classList.add("open");
  <% end %>
</script>
<% end %>