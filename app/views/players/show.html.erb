<% content_for :title, "My Stats — Badminton League" %>

<% content_for :head do %>
<style>
  .pd-shell { min-height: 100vh; background: var(--dark-0); }

  .pd-top {
    background: var(--dark-1); border-bottom: 1px solid var(--dark-3);
    padding: 14px 32px; display: flex; align-items: center; justify-content: space-between;
  }
  .pd-brand { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 3px; color: var(--text-pri); }
  .pd-brand span { color: var(--lime); }
  .pd-top-right { display: flex; align-items: center; gap: 12px; }
  .pd-user { display: flex; align-items: center; gap: 8px; background: var(--dark-2); padding: 6px 14px 6px 8px; border-radius: 30px; font-size: 13px; color: var(--text-sec); }
  .pd-avatar { width: 28px; height: 28px; border-radius: 50%; background: linear-gradient(135deg, var(--lime), var(--lime-dim)); color: var(--dark-0); font-family: 'Bebas Neue', sans-serif; font-size: 13px; display: flex; align-items: center; justify-content: center; }
  .btn-so { background: transparent; border: 1px solid var(--dark-4); color: var(--text-sec); border-radius: 8px; padding: 6px 14px; font-size: 13px; cursor: pointer; font-family: 'Outfit', sans-serif; display: inline-flex; align-items: center; gap: 6px; transition: 0.15s; }
  .btn-so:hover { border-color: var(--danger); color: var(--danger); }

  .pd-wrap { max-width: 960px; margin: 0 auto; padding: 40px 32px; }

  .pd-hero { margin-bottom: 36px; }
  .pd-hero .eyebrow { font-size: 11px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--lime); margin-bottom: 8px; }
  .pd-hero h1 { font-family: 'Bebas Neue', sans-serif; font-size: 46px; letter-spacing: 2px; color: var(--text-pri); line-height: 1; margin-bottom: 6px; }
  .pd-hero p { color: var(--text-sec); font-size: 14px; }

  .stat-row { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-bottom: 32px; }
  .s-card { background: var(--dark-1); border: 1px solid var(--dark-3); border-radius: 10px; padding: 18px 20px; position: relative; overflow: hidden; }
  .s-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; }
  .s-card.lime::before   { background: var(--lime); }
  .s-card.blue::before   { background: #4dabf7; }
  .s-card.green::before  { background: #51cf66; }
  .s-card.red::before    { background: var(--danger); }
  .s-card.orange::before { background: #fd7e14; }
  .s-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 14px; margin-bottom: 12px; }
  .s-card.lime   .s-icon { background: rgba(198,241,53,0.1); color: var(--lime); }
  .s-card.blue   .s-icon { background: rgba(77,171,247,0.1); color: #4dabf7; }
  .s-card.green  .s-icon { background: rgba(81,207,102,0.1); color: #51cf66; }
  .s-card.red    .s-icon { background: rgba(255,77,77,0.1);  color: var(--danger); }
  .s-card.orange .s-icon { background: rgba(253,126,20,0.1); color: #fd7e14; }
  .s-val { font-family: 'Bebas Neue', sans-serif; font-size: 36px; color: var(--text-pri); line-height: 1; margin-bottom: 2px; }
  .s-lbl { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: var(--text-sec); }

  .d-card { background: var(--dark-1); border: 1px solid var(--dark-3); border-radius: 10px; overflow: hidden; }
  .d-head { padding: 16px 20px; border-bottom: 1px solid var(--dark-3); display: flex; align-items: center; justify-content: space-between; }
  .d-title { font-family: 'Bebas Neue', sans-serif; font-size: 17px; letter-spacing: 1.5px; color: var(--text-pri); }
  .d-badge { background: var(--dark-3); color: var(--text-sec); font-size: 11px; font-weight: 600; padding: 2px 10px; border-radius: 20px; }

  table { width: 100%; border-collapse: collapse; }
  thead th { padding: 10px 18px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-dim); text-align: left; background: var(--dark-2); border-bottom: 1px solid var(--dark-3); }
  tbody tr { border-bottom: 1px solid rgba(255,255,255,0.04); transition: background 0.12s; }
  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: var(--dark-2); }
  tbody td { padding: 12px 18px; font-size: 13px; color: var(--text-pri); }

  .badge-win  { background: rgba(81,207,102,0.12); color: #51cf66; border: 1px solid rgba(81,207,102,0.25); border-radius: 6px; padding: 3px 10px; font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }
  .badge-loss { background: rgba(255,77,77,0.1);   color: #ff6b6b; border: 1px solid rgba(255,77,77,0.2);  border-radius: 6px; padding: 3px 10px; font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }

  .p-chip { display: inline-flex; align-items: center; gap: 6px; background: var(--dark-3); border-radius: 20px; padding: 2px 10px 2px 4px; font-size: 13px; }
  .p-chip .av { width: 20px; height: 20px; border-radius: 50%; background: linear-gradient(135deg, var(--lime), var(--lime-dim)); color: var(--dark-0); font-size: 9px; font-family: 'Bebas Neue', sans-serif; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .tag-league   { font-size: 11px; background: rgba(77,171,247,0.1); color: #4dabf7; border-radius: 4px; padding: 2px 8px; font-weight: 500; }
  .tag-friendly { font-size: 11px; background: rgba(198,241,53,0.1); color: var(--lime); border-radius: 4px; padding: 2px 8px; font-weight: 500; }

  .empty { padding: 48px; text-align: center; color: var(--text-dim); }
  .empty i { font-size: 32px; display: block; margin-bottom: 10px; }
  .empty p { font-size: 14px; }

  .wr-wrap { display: flex; align-items: center; gap: 8px; }
  .wr-bar { flex: 1; height: 6px; background: var(--dark-4); border-radius: 3px; overflow: hidden; max-width: 100px; }
  .wr-fill { height: 100%; background: var(--lime); border-radius: 3px; }
  .wr-pct { font-size: 13px; font-weight: 600; color: var(--lime); }

  .leagues-list { display: flex; flex-wrap: wrap; gap: 8px; padding: 16px 20px; }
  .league-pill { background: var(--dark-3); border: 1px solid var(--dark-4); border-radius: 8px; padding: 8px 14px; display: flex; align-items: center; gap: 8px; text-decoration: none; transition: border-color 0.15s; }
  .league-pill:hover { border-color: var(--lime); }
  .league-pill .lp-name { font-size: 13px; color: var(--text-pri); font-weight: 500; }
  .league-pill .lp-cnt { font-size: 11px; color: var(--text-sec); }
</style>
<% end %>

<div class="pd-shell">

  <%# ── top bar ── %>
  <div class="pd-top">
    <div class="pd-brand">BADMINTON<span>LEAGUE</span></div>
    <div class="pd-top-right">
      <div class="pd-user">
        <div class="pd-avatar"><%= current_user.name[0].upcase %></div>
        <%= current_user.name %>
        <span style="background:rgba(198,241,53,0.1);color:var(--lime);font-size:10px;font-weight:600;
                     text-transform:uppercase;letter-spacing:1px;border-radius:4px;padding:2px 7px;margin-left:4px">
          Player
        </span>
      </div>
      <%= button_to session_path, method: :delete, class: "btn-so", form: { "data-turbo": false } do %>
        <i class="bi bi-box-arrow-right"></i> Sign Out
      <% end %>
    </div>
  </div>

  <div class="pd-wrap">

    <%# ── hero ── %>
    <div class="pd-hero">
      <div class="eyebrow">Player Dashboard</div>
      <h1>HI, <%= current_user.name.split.first.upcase %> 👋</h1>
      <p>Here's your personal performance summary across all matches and leagues.</p>
    </div>

    <%# ── stat cards ── %>
    <div class="stat-row">
      <div class="s-card lime">
        <div class="s-icon"><i class="bi bi-bullseye"></i></div>
        <div class="s-val"><%= @stats[:total] %></div>
        <div class="s-lbl">Total Matches</div>
      </div>
      <div class="s-card green">
        <div class="s-icon"><i class="bi bi-trophy-fill"></i></div>
        <div class="s-val"><%= @stats[:wins] %></div>
        <div class="s-lbl">Wins</div>
      </div>
      <div class="s-card red">
        <div class="s-icon"><i class="bi bi-x-circle-fill"></i></div>
        <div class="s-val"><%= @stats[:losses] %></div>
        <div class="s-lbl">Losses</div>
      </div>
      <div class="s-card orange">
        <div class="s-icon"><i class="bi bi-graph-up-arrow"></i></div>
        <div class="s-val"><%= @stats[:win_pct] %>%</div>
        <div class="s-lbl">Win Rate</div>
      </div>
      <div class="s-card blue">
        <div class="s-icon"><i class="bi bi-shield-fill"></i></div>
        <div class="s-val"><%= @stats[:leagues] %></div>
        <div class="s-lbl">Leagues</div>
      </div>
    </div>

    <%# ── leagues the player belongs to ── %>
    <% if current_user.leagues.any? %>
      <div class="d-card" style="margin-bottom:24px">
        <div class="d-head">
          <span class="d-title">MY LEAGUES</span>
          <span class="d-badge"><%= current_user.leagues.count %> leagues</span>
        </div>
        <div class="leagues-list">
          <% current_user.leagues.includes(:matches, :members).each do |league| %>
            <div class="league-pill">
              <i class="bi bi-shield" style="color:var(--lime);font-size:14px"></i>
              <span class="lp-name"><%= league.name %></span>
              <span class="lp-cnt">
                <%= league.matches.involving(current_user).count %> matches ·
                <%= league.members.count %> players
              </span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── match history table ── %>
    <div class="d-card">
      <div class="d-head">
        <span class="d-title">MY MATCH HISTORY</span>
        <span class="d-badge"><%= @matches.count %> matches</span>
      </div>

      <% if @matches.any? %>
        <table>
          <thead>
            <tr>
              <th style="width:56px">#</th>
              <th>Result</th>
              <th>Opponent</th>
              <th>League</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% @matches.each do |match| %>
              <% won = match.winner_id == current_user.id %>
              <% opponent = won ? match.loser : match.winner %>
              <tr>
                <td style="color:var(--text-dim);font-size:12px">#<%= match.id %></td>
                <td>
                  <% if won %>
                    <span class="badge-win">Win</span>
                  <% else %>
                    <span class="badge-loss">Loss</span>
                  <% end %>
                </td>
                <td>
                  <span class="p-chip">
                    <span class="av"><%= opponent.name[0].upcase %></span>
                    <%= opponent.name %>
                  </span>
                </td>
                <td>
                  <% if match.league %>
                    <span class="tag-league"><%= match.league.name %></span>
                  <% else %>
                    <span class="tag-friendly">Friendly</span>
                  <% end %>
                </td>
                <td style="color:var(--text-sec);font-size:12px">
                  <%= match.created_at.strftime("%d %b %Y") %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="empty">
          <i class="bi bi-trophy"></i>
          <p>No matches recorded yet. Ask your admin to record your first match!</p>
        </div>
      <% end %>
    </div>

  </div>
</div>