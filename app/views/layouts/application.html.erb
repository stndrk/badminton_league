<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= content_for(:title) || "Badminton League" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <%= yield :head %>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <style>
    :root {
      --lime:      #c6f135;
      --lime-dim:  #9ec42a;
      --dark-0:    #0d0f0e;
      --dark-1:    #131613;
      --dark-2:    #1a1e1a;
      --dark-3:    #222722;
      --dark-4:    #2c332c;
      --text-pri:  #eef2e6;
      --text-sec:  #8a9485;
      --text-dim:  #4e5a4e;
      --danger:    #ff4d4d;
      --warning:   #f5c518;
      --radius:    10px;
      --sidebar-w: 240px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--dark-0);
      color: var(--text-pri);
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      line-height: 1.6;
      min-height: 100vh;
    }

    .flash-container {
      position: fixed;
      top: 16px;
      right: 16px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .flash-msg {
      padding: 12px 20px;
      border-radius: var(--radius);
      font-weight: 500;
      font-size: 13px;
      animation: slideIn 0.3s ease;
      cursor: pointer;
    }

    .flash-msg.notice { background: var(--lime); color: var(--dark-0); }
    .flash-msg.alert  { background: var(--danger); color: #fff; }

    @keyframes slideIn {
      from { transform: translateX(40px); opacity: 0; }
      to   { transform: translateX(0); opacity: 1; }
    }

    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: var(--dark-1); }
    ::-webkit-scrollbar-thumb { background: var(--dark-4); border-radius: 4px; }
  </style>

  <%= yield :head %>
</head>
<body>

  <!-- Flash Messages -->
  <div class="flash-container">
    <% flash.each do |type, message| %>
      <div class="flash-msg <%= type %>" onclick="this.remove()">
        <%= message %>
      </div>
    <% end %>
  </div>

  <%= yield %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Auto-dismiss flash messages
    document.querySelectorAll('.flash-msg').forEach(el => {
      setTimeout(() => el.remove(), 4000);
    });
  </script>

  <%= yield :scripts %>
</body>
</html>